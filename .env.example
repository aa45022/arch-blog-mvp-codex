# ═══════════════════════════════════════════════
# 環境變數範本 — 複製為 .env 後填入實際值
# ═══════════════════════════════════════════════

# ─── 資料庫（stage:1）───
# 本地開發：postgresql://使用者:密碼@localhost:5432/arch_blog
# Zeabur：請在 App 服務環境變數至少設定 DATABASE_URL（建議）
# 若 Zeabur 只提供 POSTGRES_URL / POSTGRES_PRISMA_URL，也可直接使用（程式已支援）
DATABASE_URL="postgresql://postgres:tony890706@localhost:5432/arch_blog"

# ─── 網站 URL（stage:1）───
# 用於 Origin 檢查，寫入 API 比對用
# 本地開發用 http://localhost:3000，部署後改為實際域名
APP_URL="http://localhost:3000"

# ─── Cloudinary（stage:1）───
# 前往 https://cloudinary.com/console 取得
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# 前端上傳用（Next.js 要求 NEXT_PUBLIC_ 前綴才能在 client 使用）
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"

# Cloudinary 圖片上傳（改進3）
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=arch_blog_unsigned

# 網站公開 URL（OG Meta 用，改進5）
NEXT_PUBLIC_SITE_URL=https://arch-blog.zeabur.app

# ─── 管理後台（可選，但建議設定）───
ADMIN_SECRET=""

# 首次建立管理員 API 金鑰（若有設定，/admin/setup 需輸入）
ADMIN_SETUP_KEY=""

# 後台驗證開關：預設停用保護（true）。
# 全部確認完畢後請改為 false 重新啟用登入防護。
ADMIN_AUTH_DISABLED="true"
