# ═══════════════════════════════════════════════
# 環境變數範本 — 複製為 .env 後填入實際值
# ═══════════════════════════════════════════════

# ─── 資料庫（stage:1）───
# 本地開發：postgresql://使用者:密碼@localhost:5432/arch_blog
# Zeabur：由 PostgreSQL service 自動注入
DATABASE_URL="postgresql://postgres:tony890706@localhost:5432/arch_blog"

# ─── 網站 URL（stage:1）───
# 用於 Origin 檢查，寫入 API 比對用
# 本地開發用 http://localhost:3000，部署後改為實際域名
APP_URL="http://localhost:3000"

# ─── Cloudinary（stage:1）───
# 前往 https://cloudinary.com/console 取得
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# 前端上傳用（Next.js 要求 NEXT_PUBLIC_ 前綴才能在 client 使用）
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
