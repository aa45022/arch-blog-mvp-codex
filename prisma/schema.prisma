// ═══════════════════════════════════════════════
// Prisma Schema — SITE LAB 敷地實驗室
// generator: prisma-client（Prisma 7 Rust-free）
// output:    ./generated/prisma（不在 node_modules）
// ═══════════════════════════════════════════════

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

// datasource 只寫 provider，url 在 prisma.config.ts 設定
datasource db {
  provider = "postgresql"
}

// ─── 管理員 ───
model AdminUser {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String    // bcrypt hash, 12 rounds
  createdAt DateTime  @default(now())
  sessions  Session[]
}

// ─── 文章 ───
model Post {
  id         Int       @id @default(autoincrement())
  title      String
  slug       String    @unique
  excerpt    String    // 摘要，用於首頁卡片
  content    String    // Markdown 原文
  coverImage String?   // Cloudinary URL（nullable）
  published  Boolean   @default(false)
  featured   Boolean   @default(false)  // 精選文章（Hero 用）
  viewCount  Int       @default(0)      // 閱讀數統計
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  categoryId Int
  category   Category  @relation(fields: [categoryId], references: [id])
  tags       Tag[]     // 隱式多對多（Prisma 自動建 _PostToTag 中間表）
  versions   PostVersion[]
}

// ─── 分類 ───
model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  slug  String @unique
  posts Post[]
}

// ─── 標籤 ───
model Tag {
  id    Int    @id @default(autoincrement())
  name  String @unique
  slug  String @unique
  posts Post[] // 隱式多對多
}

// ─── Session ───
model Session {
  id          Int       @id @default(autoincrement())
  token       String    @unique
  expiresAt   DateTime
  adminUserId Int
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id])
}

// ─── 文章版本歷史 ───
model PostVersion {
  id        Int      @id @default(autoincrement())
  postId    Int
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  title     String
  content   String   // Markdown 原文快照
  excerpt   String
  note      String?  // 版本備註（選填）
  createdAt DateTime @default(now())

  @@index([postId, createdAt(sort: Desc)])
}
